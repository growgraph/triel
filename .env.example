# ─── Triel Server Configuration ──────────────────────────────────────────────
# Copy this file to .env and adjust values as needed
# All configuration can be provided via environment variables

# ─── Server Configuration (TRIEL_SERVER_*) ──────────────────────────────────
# Server host address
TRIEL_SERVER_HOST=0.0.0.0

# Server port
TRIEL_SERVER_PORT=8592

# Number of concurrent threads
TRIEL_SERVER_THREADS=8

# Enable debug logging
TRIEL_SERVER_DEBUG=false

# ─── WSGI Configuration (TRIEL_WSGI_*) ──────────────────────────────────────
# Protocol (http/https)
TRIEL_WSGI_PROTOCOL=http

# Database type
TRIEL_WSGI_DB_TYPE=wsgi

# IP address
TRIEL_WSGI_IP_ADDR=localhost

# API endpoint paths
TRIEL_WSGI_PATHS_PARSE=/v3/parse
TRIEL_WSGI_PATHS_PARSE_ENTITIES=/v3/parse/entities
TRIEL_WSGI_PATHS_PARSE_DETAILED=/v3/parse/detailed

# Alternative: Provide entire WSGI config as JSON string (minified, all on one line)
# TRIEL_WSGI_CONFIG_JSON={"protocol":"http","db_type":"wsgi","ip_addr":"localhost","host":"0.0.0.0","port":8592,"paths":{"parse":"/v3/parse","parse/entities":"/v3/parse/entities","parse/detailed":"/v3/parse/detailed"}}

# Alternative: Path to WSGI config file (JSON/YAML)
# TRIEL_WSGI_CONFIG_FILE=self.json

# ─── Model Configuration (TRIEL_MODEL_*) ─────────────────────────────────────
# Enable GPU for spaCy models
TRIEL_MODEL_GPU=true

# spaCy model name
TRIEL_MODEL_SPACY_MODEL=en_core_web_trf

# Rules configuration file name
TRIEL_MODEL_RULES_FILE=prune_noun_compound_v3.yaml

# Rules configuration path
TRIEL_MODEL_RULES_PATH=triel.config

# ─── Entity Linker Configuration (TRIEL_LINKER_*) ───────────────────────────
# Option 1: Provide linker config as JSON string (recommended for env-only setup)
# Minified JSON (all on one line):
TRIEL_LINKER_CONFIG_JSON={"linkers":[{"keyword":"BERN_V2","route":"plain","port":8888,"text_field":"text","entities_key":"annotations","threshold":0.0},{"keyword":"PELINKER","route":"link","port":8599,"text_field":"text","normalized_text_key":"normalized_text","threshold":0.5},{"keyword":"FISHING","route":"service/disambiguate","port":8590,"protocol":"http","text_field":"text","threshold":0.55,"extra_args":{"language":{"lang":"en"},"mentions":["ner","wikipedia"]}}]}

# Option 2: Path to entity linker config file (YAML/JSON)
# TRIEL_LINKER_CONFIG_FILE=el_config.yaml

# Override host for all linkers (optional)
# TRIEL_LINKER_HOST_OVERRIDE=192.168.1.11

# ─── Example: Multi-linker configuration as JSON ──────────────────────────────
# For better readability, here's the linker config formatted:
#
# {
#   "linkers": [
#     {
#       "keyword": "BERN_V2",
#       "route": "plain",
#       "port": 8888,
#       "text_field": "text",
#       "entities_key": "annotations",
#       "threshold": 0.0
#     },
#     {
#       "keyword": "PELINKER",
#       "route": "link",
#       "port": 8599,
#       "text_field": "text",
#       "normalized_text_key": "normalized_text",
#       "threshold": 0.5
#     },
#     {
#       "keyword": "FISHING",
#       "route": "service/disambiguate",
#       "port": 8590,
#       "protocol": "http",
#       "text_field": "text",
#       "threshold": 0.55,
#       "extra_args": {
#         "language": {
#           "lang": "en"
#         },
#         "mentions": ["ner", "wikipedia"]
#       }
#     }
#   ]
# }
#
# Minify this JSON and set it as TRIEL_LINKER_CONFIG_JSON

# ─── Client Configuration (TRIEL_CLIENT_*) ───────────────────────────────────
# Base URL of the Triel server (used by TrielClient)
TRIEL_CLIENT_BASE_URL=http://localhost:8592

# API endpoint paths (used by TrielClient)
TRIEL_CLIENT_PARSE_PATH=/v3/parse
TRIEL_CLIENT_PARSE_DETAILED_PATH=/v3/parse/detailed
TRIEL_CLIENT_PARSE_ENTITIES_PATH=/v3/parse/entities

# Request timeout in seconds
TRIEL_CLIENT_TIMEOUT=30.0

# Whether to verify SSL certificates
TRIEL_CLIENT_VERIFY=true
